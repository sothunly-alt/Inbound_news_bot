dotenvTELEGRAM_BOT_TOKEN="your-telegram-bot-token"
GROQ_API_KEY="your-groq-api-key"
TELEGRAM_CHANNEL_ID="your-channel-id"
TELEGRAM_THREAD_ID="your-thread-id"

# Optional — enables persistent state on Railway/Render (get free URL at upstash.com)
REDIS_URL="redis://default:your-password@your-host.upstash.io:6379"

# Polling interval (seconds between feed checks)
POLL_INTERVAL_SECONDS=1200

# Supabase — bot writes each posted story here for the website to read
SUPABASE_URL="https://woldqxujzbxdhaopolme.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"